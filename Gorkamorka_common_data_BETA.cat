      <infoLinks>
        <infoLink name="11 Ammo test" id="405b-fee7-5b58-3fa0" hidden="false" type="rule" targetId="a67f-510b-c01b-8c72"/>
        <infoLink name="12 Catching fire" id="20af-5ffd-c6b3-668a" hidden="false" type="rule" targetId="0bab-d885-3d89-4d70"/>
        <infoLink name="13 Template" id="05d5-864c-94b3-35df" hidden="false" type="rule" targetId="c097-af8b-c2de-ac04"/>
      </infoLinks>
      <rules>
        <rule name="Kustom (Special)" id="2de7-4c9d-8b82-1788" hidden="false">
          <description>Shootier or Longer Range only. 
Any subsequent upgrade will reduce the effect of the 
other option. Range changes are done using the three 
teardrop template sizes - Hand Flamer Template, 
Flamer Template, Heavy Flamer Template (4”, 8”, and 
16” long respectively).</description>
        </rule>
      </rules>
      <costs>
        <cost name="Teef" typeId="points" value="8"/>
        <cost name="Mob rating" typeId="wb-rating" value="8"/>
      </costs>
    </selectionEntry>
