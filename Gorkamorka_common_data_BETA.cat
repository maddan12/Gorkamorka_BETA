        <profile id="7888-0782-642f-92ae" name="Chain" page="0" hidden="false" typeId="9db87680-6ee5-b46c-48ca-dcd1c5de1bad" typeName="H2H Weapon">
          <characteristics>
            <characteristic name="Range - Short" typeId="bd0c-30c9-2027-2c4e">-</characteristic>
