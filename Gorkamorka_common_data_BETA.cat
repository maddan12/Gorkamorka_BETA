    <selectionEntryGroup id="313b-a816-0a89-926c" name="Serious Injuries" hidden="false" collective="false" import="true" collapsible="true">
      <constraints>
        <constraint field="selections" scope="parent" value="0" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="9d3f-3246-67fd-9817" type="min"/>
      </constraints>
      <selectionEntries>
        <selectionEntry id="9927-6360-269c-7050" name="Leg Wound" page="0" hidden="false" collective="false" import="true" type="upgrade" sortIndex="1">
          <rules>
            <rule id="c847-ef0d-c229-d784" name="Leg Wound" page="0" hidden="false">
              <description>The warrior’s leg is broken. He suffers a -1 Movement characteristic penalty from now on.</description>
            </rule>
          </rules>
          <entryLinks>
            <entryLink id="2086-9b92-d7d1-ac86" name="-1 M" hidden="false" collective="false" import="true" targetId="7dee-74f8-7707-ce64" type="selectionEntry">
              <constraints>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="e50a-2635-768f-479d" type="min"/>
                <constraint field="selections" scope="parent" value="1" percentValue="false" shared="true" includeChildSelections="false" includeChildForces="false" id="b9e5-dd09-c7b0-2150" type="max"/>
              </constraints>
            </entryLink>
          </entryLinks>
          <costs>
            <cost name=" gc" typeId="points" value="0"/>
            <cost name=" Warband Rating" typeId="wb-rating" value="0"/>
            <cost name=" Rarity" typeId="rarity" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="7d82-1ea4-5499-172c" name="Severe Arm Wound" page="0" hidden="false" collective="false" import="true" type="upgrade" sortIndex="2">
          <rules>
            <rule id="428e-09c4-6969-6155" name="Severe Arm Wound" page="0" hidden="false">
              <description>Severe arm wound. The arm must be amputated. The warrior may only use a single onehanded weapon from now on</description>
            </rule>
          </rules>
          <selectionEntries>
            <selectionEntry id="b0dc-4bdd-e2ad-7e43" name="DummyEntry" hidden="true" collective="false" import="true" type="upgrade">
              <costs>
                <cost name=" gc" typeId="points" value="0"/>
                <cost name=" Warband Rating" typeId="wb-rating" value="0"/>
                <cost name=" Rarity" typeId="rarity" value="0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
          <costs>
            <cost name=" gc" typeId="points" value="0"/>
            <cost name=" Warband Rating" typeId="wb-rating" value="0"/>
            <cost name=" Rarity" typeId="rarity" value="0"/>
          </costs>
        </selectionEntry>
        <selectionEntry id="f480-dbf6-473e-d864" name="Madness: Stupidity" page="0" hidden="false" collective="false" import="true" type="upgrade" sortIndex="3">
          <infoLinks>
            <infoLink id="babf-70b4-0e56-27a5" name="Stupidity" hidden="false" targetId="20f0-4428-0681-c9f9" type="rule"/>
          </infoLinks>
          <selectionEntries>
