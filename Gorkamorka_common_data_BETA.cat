            <characteristic name="Ammo Roll" typeId="3c40-a909-9897-ed80">-</characteristic>
            <characteristic name="Special/Notes" typeId="80dd3fd5-3811-af0b-e182-2ecbc7ad5d8e">Opponent May Not Block: Warriors armed with a 
Chain cannot be forced to reroll a blocked Attack (e.g. 
using a Shield)
Fumbles Count Double: Fumbles rolled by a Warrior 
armed with a Chain count as +2 to their opponent’s 
score, rather than the usual +1</characteristic>
          </characteristics>
        </profile>
      </profiles>
