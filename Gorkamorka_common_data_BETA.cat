        <entryLink import="true" name="Gubbinz - Big Grabber" hidden="false" id="744f-a569-e1ec-f874" type="selectionEntry" targetId="b56c-af7e-9c24-a5b1"/>
        <entryLink import="true" name="Gubbinz - Boarding plank" hidden="false" id="e43d-224b-0df3-ea52" type="selectionEntry" targetId="43e4-b7c4-bd70-05d1"/>
