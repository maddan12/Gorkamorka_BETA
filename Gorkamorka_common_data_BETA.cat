    <selectionEntry type="upgrade" import="true" name="Big Gunz - Rokkit Launcha" hidden="false" id="45ad-f501-0ffe-dd59">
      <profiles>
        <profile name="Big Gunz - Rokkit Launcha" typeId="c4b0233c-e5d1-2b41-3446-45a745fbbbec" typeName="Gunz - Weapons" hidden="false" id="0c28-0319-cafc-977c">
          <characteristics>
            <characteristic name="Range - Short" typeId="a275054b-9b3d-9e68-49e9-7fbb6c714412">0-12&quot;</characteristic>
            <characteristic name="Range - Long" typeId="2885-63e8-dfad-3e69">12-30&quot;</characteristic>
            <characteristic name="To Hit - Short" typeId="67a0-32af-4c28-dc51">-</characteristic>
